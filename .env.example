# Vector index — run: python scripts/build_corpus_index.py
COMPLIANCE_INDEX_DIR=vector_store/regulatory
COMPLIANCE_USE_DEMO_INDEX=false

# Embeddings
COMPLIANCE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# After fine-tuning: python scripts/finetune_embeddings.py
# COMPLIANCE_EMBEDDING_MODEL=models/compliance-embeddings
# COMPLIANCE_INDEX_DIR=vector_store/regulatory-finetuned

COMPLIANCE_MIN_RETRIEVAL_SCORE=0.22
COMPLIANCE_RETRIEVAL_TOP_K=6

# LLM: ollama (local) | openai | template (fallback when Ollama unavailable)
COMPLIANCE_LLM_PROVIDER=ollama
COMPLIANCE_LLM_MODEL=compliance-llm
COMPLIANCE_OLLAMA_BASE_URL=http://127.0.0.1:11434
COMPLIANCE_LLM_TIMEOUT_SECONDS=120

# OpenAI — uncomment to use instead of Ollama
# COMPLIANCE_LLM_PROVIDER=openai
# COMPLIANCE_LLM_API_KEY=sk-...
# COMPLIANCE_LLM_MODEL=gpt-4o-mini

# Frontend
COMPLIANCE_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
COMPLIANCE_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/legal_ai

# Uploaded documents
COMPLIANCE_UPLOAD_DIR=data/uploads
