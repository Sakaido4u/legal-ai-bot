# Vector index — run: python scripts/build_corpus_index.py
COMPLIANCE_INDEX_DIR=vector_store/regulatory
COMPLIANCE_USE_DEMO_INDEX=false

# Embeddings
COMPLIANCE_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# After fine-tuning: python scripts/finetune_embeddings.py
# COMPLIANCE_EMBEDDING_MODEL=models/compliance-embeddings
# COMPLIANCE_INDEX_DIR=vector_store/regulatory-finetuned

COMPLIANCE_MIN_RETRIEVAL_SCORE=0.22
COMPLIANCE_RETRIEVAL_TOP_K=6

# LLM: ollama (local) | openai | template (fallback when Ollama unavailable)
COMPLIANCE_LLM_PROVIDER=ollama
COMPLIANCE_LLM_MODEL=compliance-llm
COMPLIANCE_OLLAMA_BASE_URL=http://127.0.0.1:11434
COMPLIANCE_LLM_TIMEOUT_SECONDS=120

# OpenAI — uncomment to use instead of Ollama
# COMPLIANCE_LLM_PROVIDER=openai
# COMPLIANCE_LLM_API_KEY=sk-...
# COMPLIANCE_LLM_MODEL=gpt-4o-mini

# Frontend (Vite default :3000; :5173 if you use stock Vite port)
COMPLIANCE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL (either name works — DATABASE_URL takes precedence)
# Local-dev format — Settings normalizes postgresql:// → postgresql+psycopg2://
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/legal_ai
# COMPLIANCE_DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/legal_ai

# Uploaded documents
COMPLIANCE_UPLOAD_DIR=data/uploads

# App environment: development | production
# In development, password-reset tokens are logged (and optionally returned) for local testing.
COMPLIANCE_APP_ENV=development
COMPLIANCE_FRONTEND_BASE_URL=http://localhost:3000

# Auth / JWT — REQUIRED. No weak default. Generate a strong secret:
#   openssl rand -hex 32
#   (or) python -c "import secrets; print(secrets.token_hex(32))"
COMPLIANCE_JWT_SECRET=
COMPLIANCE_JWT_EXPIRE_MINUTES=10080

# Rate limits (slowapi format: "N/minute", "N/hour", …)
COMPLIANCE_RATE_LIMIT_AUTH=10/minute
COMPLIANCE_RATE_LIMIT_UPLOAD=20/minute
COMPLIANCE_RATE_LIMIT_ANALYZE=30/minute

# Password-reset email (SMTP). When unset in development, tokens are logged only.
# COMPLIANCE_SMTP_HOST=smtp.example.com
# COMPLIANCE_SMTP_PORT=587
# COMPLIANCE_SMTP_USER=
# COMPLIANCE_SMTP_PASSWORD=
# COMPLIANCE_SMTP_FROM=noreply@lexai.local
# COMPLIANCE_SMTP_USE_TLS=true
